Cell 1 — Import Libraries
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
Cell 2 — Load Dataset
df = pd.read_csv("../data/customer_data.csv")
df.head()
Cell 3 — Dataset Shape
df.shape
Cell 4 — Dataset Information
df.info()
Cell 5 — Check Missing Values
df.isnull().sum()
Cell 6 — Statistical Summary
df.describe()
Cell 7 — Correlation Heatmap
plt.figure(figsize=(10,6))

sns.heatmap(
    df.corr(numeric_only=True),
    annot=True,
    cmap='coolwarm'
)

plt.title("Correlation Heatmap")

plt.show()
Cell 8 — Distribution Plot
plt.figure(figsize=(8,5))

sns.histplot(
    df['Annual Income (k$)'],
    kde=True
)

plt.title("Annual Income Distribution")

plt.show()
Cell 9 — Scatter Plot
plt.figure(figsize=(8,5))

sns.scatterplot(
    x='Age',
    y='Spending Score (1-100)',
    hue='Gender',
    data=df
)

plt.title("Age vs Spending Score")

plt.show()
Cell 10 — Average Spending Score
avg_spending = df.groupby('Gender')['Spending Score (1-100)'].mean()

avg_spending
